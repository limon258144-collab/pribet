{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "status": { "type": "string" },
        "username": { "type": "string" },
        "typingTo": { "type": "string" },
        "lastSeen": { "type": "string", "format": "date-time" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "phoneNumber"]
    },
    "Message": {
      "title": "Message",
      "description": "Chat message structure",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "imageUrl": { "type": "string" },
        "videoUrl": { "type": "string" },
        "voiceUrl": { "type": "string" },
        "voiceDuration": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["sent", "delivered", "read"] },
        "type": { "type": "string", "enum": ["text", "image", "voice", "video"] },
        "reactions": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "senderId", "timestamp", "status", "type"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a chat"
    }
  }
}
